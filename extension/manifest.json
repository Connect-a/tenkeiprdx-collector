{
  "manifest_version": 3,
  "name": "天啓パラドクス コレクター",
  "version": "1.0.0",
  "description": "天啓パラドクスの非公式リソースダウンロード＆プレイヤーです。",
  "permissions": ["debugger", "storage", "unlimitedStorage", "tabs", "alarms"],
  "host_permissions": [
    "*://play.games.dmm.co.jp/*",
    "*://play.games.dmm.com/*",
    "*://*.tenkei-paradox.com/*"
  ],
  "content_security_policy": { "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'" },
  "icons": { "16": "icons/icon-16.png", "32": "icons/icon-32.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "天啓パラドクス コレクター（クリックでビューアを開く）",
    "default_icon": { "16": "icons/icon-16.png", "32": "icons/icon-32.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
  }
}
